# Qryvanta reference scaling profile: small-cluster
# Target: small production footprint with HA API and worker pool.

# Deployment shape
# - API replicas: 2
# - Worker replicas: 2-3
# - Postgres: managed single primary with backup
# - Redis: required shared service

WORKFLOW_EXECUTION_MODE=queued
SESSION_STORE=redis
RATE_LIMIT_STORE=redis
WORKFLOW_QUEUE_STATS_CACHE_BACKEND=redis

WORKER_MAX_CONCURRENCY=8
WORKER_CLAIM_LIMIT=20
WORKFLOW_WORKER_MAX_CLAIM_LIMIT=30

RUNTIME_QUERY_MAX_LIMIT=200
RUNTIME_QUERY_MAX_IN_FLIGHT=48
WORKFLOW_BURST_MAX_IN_FLIGHT=24

WORKFLOW_QUEUE_STATS_CACHE_TTL_SECONDS=2
SLOW_REQUEST_THRESHOLD_MS=800
SLOW_QUERY_THRESHOLD_MS=200
