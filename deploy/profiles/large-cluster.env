# Qryvanta reference scaling profile: large-cluster
# Target: high-volume multi-tenant footprint.

# Deployment shape
# - API replicas: 6+
# - Worker replicas: 8+
# - Postgres: managed HA with read replicas
# - Redis: required (dedicated/HA)

WORKFLOW_EXECUTION_MODE=queued
SESSION_STORE=redis
RATE_LIMIT_STORE=redis
WORKFLOW_QUEUE_STATS_CACHE_BACKEND=redis

WORKER_MAX_CONCURRENCY=16
WORKER_CLAIM_LIMIT=25
WORKFLOW_WORKER_MAX_CLAIM_LIMIT=40

RUNTIME_QUERY_MAX_LIMIT=300
RUNTIME_QUERY_MAX_IN_FLIGHT=160
WORKFLOW_BURST_MAX_IN_FLIGHT=80

WORKFLOW_QUEUE_STATS_CACHE_TTL_SECONDS=1
SLOW_REQUEST_THRESHOLD_MS=700
SLOW_QUERY_THRESHOLD_MS=150
