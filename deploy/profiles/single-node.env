# Qryvanta reference scaling profile: single-node
# Target: local/internal workloads with one API process and one worker process.

# Deployment shape
# - API replicas: 1
# - Worker replicas: 1
# - Postgres: single instance
# - Redis: optional

WORKFLOW_EXECUTION_MODE=queued
SESSION_STORE=postgres
RATE_LIMIT_STORE=postgres
WORKFLOW_QUEUE_STATS_CACHE_BACKEND=in_memory

WORKER_MAX_CONCURRENCY=4
WORKER_CLAIM_LIMIT=10
WORKFLOW_WORKER_MAX_CLAIM_LIMIT=25

RUNTIME_QUERY_MAX_LIMIT=120
RUNTIME_QUERY_MAX_IN_FLIGHT=16
WORKFLOW_BURST_MAX_IN_FLIGHT=8

WORKFLOW_QUEUE_STATS_CACHE_TTL_SECONDS=2
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=250
