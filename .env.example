# API runtime
API_HOST=127.0.0.1
API_PORT=3001
FRONTEND_URL=http://localhost:3000
# Used by secret reuse drift detection and print-secret-fingerprints commands.
DEPLOYMENT_ENVIRONMENT=local
# JSON array of fingerprint records exported from other environments.
# Example:
# SECRET_REUSE_GUARD_FINGERPRINTS=[{"environment":"staging","secret_name":"SESSION_SECRET","fingerprint":"..."}]
SECRET_REUSE_GUARD_FINGERPRINTS=

# Secret source options for secret-valued settings:
# 1. direct env: SESSION_SECRET=...
# 2. file path: SESSION_SECRET_FILE=/run/secrets/session_secret
# 3. secret manager reference: SESSION_SECRET_SECRET_REF=op://vault/item/password
# Only configure one source per setting.
# Supported *_SECRET_REF schemes:
# - op://vault/item/field
# - aws-sm://secret-id
# - aws-ssm:///parameter/name
# - vault://path#field
# - gcp-sm://projects/<project>/secrets/<secret>/versions/<version>

# Postgres
DATABASE_URL=postgres://qryvanta:qryvanta@127.0.0.1:5432/qryvanta

# Physical tenant isolation profile (optional)
# shared | tenant_per_schema | tenant_per_database
PHYSICAL_ISOLATION_MODE=shared
# Required when PHYSICAL_ISOLATION_MODE is tenant_per_schema or tenant_per_database
PHYSICAL_ISOLATION_TENANT_ID=
# Required when PHYSICAL_ISOLATION_MODE=tenant_per_schema (must contain {tenant_id})
PHYSICAL_ISOLATION_SCHEMA_TEMPLATE=
# Required when PHYSICAL_ISOLATION_MODE=tenant_per_database (must contain {tenant_id})
PHYSICAL_ISOLATION_DATABASE_URL_TEMPLATE=

# First-party auth
AUTH_BOOTSTRAP_TOKEN=replace-with-strong-bootstrap-token
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000
SESSION_COOKIE_SECURE=false
TRUST_PROXY_HEADERS=false
# Comma-separated proxy IPs/CIDRs allowed to supply X-Forwarded-For/X-Real-Ip.
TRUSTED_PROXY_CIDRS=127.0.0.1/32
DEV_DEFAULT_TENANT_ID=11111111-1111-1111-1111-111111111111

# Session signing secret (hex/base64; 32+ bytes recommended)
SESSION_SECRET=replace-with-strong-random-secret
# SESSION_SECRET_FILE=/run/secrets/session_secret
# SESSION_SECRET_SECRET_REF=op://qryvanta/prod/session/secret
# static | aws_kms_envelope
TOTP_ENCRYPTION_MODE=static
TOTP_ENCRYPTION_KEY=replace-with-64-char-hex-key
# Required when TOTP_ENCRYPTION_MODE=aws_kms_envelope.
# Keep TOTP_ENCRYPTION_KEY set as a legacy fallback until older MFA enrollments have been reset or re-enrolled.
TOTP_KMS_KEY_ID=
SESSION_STORE=postgres

# Email delivery
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Redis (optional shared cache + rate limiting)
REDIS_URL=redis://127.0.0.1:6379
# REDIS_URL_SECRET_REF=aws-sm://prod/qryvanta/redis-url
RATE_LIMIT_STORE=postgres
WORKFLOW_QUEUE_STATS_CACHE_BACKEND=in_memory

# Workflow execution
WORKFLOW_EXECUTION_MODE=inline
WORKER_SHARED_SECRET=replace-with-strong-worker-shared-secret
# WORKER_SHARED_SECRET_FILE=/run/secrets/worker_shared_secret
WORKFLOW_WORKER_DEFAULT_LEASE_SECONDS=30
WORKFLOW_WORKER_MAX_CLAIM_LIMIT=25
WORKFLOW_WORKER_MAX_PARTITION_COUNT=128
WORKFLOW_QUEUE_STATS_CACHE_TTL_SECONDS=0
RUNTIME_QUERY_MAX_LIMIT=200
RUNTIME_QUERY_MAX_IN_FLIGHT=64
WORKFLOW_BURST_MAX_IN_FLIGHT=32
AUDIT_IMMUTABLE_MODE=false
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_QUERY_THRESHOLD_MS=250

# Worker runtime
WORKER_API_BASE_URL=http://127.0.0.1:3001
WORKER_ID=worker-local-1
WORKER_CLAIM_LIMIT=10
WORKER_MAX_CONCURRENCY=4
WORKER_LEASE_SECONDS=30
WORKER_POLL_INTERVAL_MS=1500
WORKER_PARTITION_COUNT=
WORKER_PARTITION_INDEX=
WORKER_COORDINATION_BACKEND=none
WORKER_COORDINATION_LEASE_SECONDS=120
WORKER_COORDINATION_SCOPE_KEY=
WORKER_LEASE_LOSS_STRATEGY=graceful_drain

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Qrywell integration (optional)
QRYWELL_API_BASE_URL=http://127.0.0.1:4201
QRYWELL_API_KEY=
QRYWELL_SYNC_POLL_INTERVAL_MS=3000
QRYWELL_SYNC_BATCH_SIZE=25
QRYWELL_SYNC_MAX_ATTEMPTS=12
