{
  "name": "@qryvanta/api-types",
  "version": "0.2.0",
  "description": "Generated TypeScript SDK contract types for the Qryvanta HTTP API.",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Neelbiehler/qryvanta"
  },
  "homepage": "https://github.com/Neelbiehler/qryvanta/tree/main/packages/api-types",
  "bugs": {
    "url": "https://github.com/Neelbiehler/qryvanta/issues"
  },
  "keywords": [
    "qryvanta",
    "api",
    "sdk",
    "contracts",
    "typescript"
  ],
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
